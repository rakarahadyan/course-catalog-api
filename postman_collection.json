          }
        },
        {
          "name": "Delete Topic (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/topics/4",
              "host": ["{{base_url}}"],
              "path": ["topics", "4"]
            }
          }
        }
      ]
    },
    {
      "name": "Languages",
