            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spanish\"\n}"
            }
          }
        },
        {
          "name": "Delete Language (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/languages/4",
              "host": ["{{base_url}}"],
              "path": ["languages", "4"]
            }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get All Courses (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/courses?page=1&limit=10&sort_by=created_at&sort_order=desc",
              "host": ["{{base_url}}"],
              "path": ["courses"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" },
                { "key": "topic_id", "value": "" },
                { "key": "language_id", "value": "" },
                { "key": "level", "value": "" },
                { "key": "min_price", "value": "" },
                { "key": "max_price", "value": "" },
                { "key": "sort_by", "value": "created_at" },
                { "key": "sort_order", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Get Course By ID (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/courses/1",
              "host": ["{{base_url}}"],
              "path": ["courses", "1"]
            }
          }
        },
        {
          "name": "Create Course (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/courses",
              "host": ["{{base_url}}"],
              "path": ["courses"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic_id\": 1,\n  \"language_id\": 1,\n  \"title\": \"Belajar JavaScript Modern\",\n  \"description\": \"Kursus lengkap JavaScript modern mencakup ES6+, async/await, modules, dan banyak lagi. Cocok untuk pemula yang ingin memulai karir di web development.\",\n  \"short_description\": \"JavaScript modern dari dasar\",\n  \"price\": 249000,\n  \"discount_rate\": 25,\n  \"thumbnail_url\": \"https://example.com/js-modern.jpg\",\n  \"level\": \"BEGINNER\"\n}"
            }
          }
        },
        {
          "name": "Update Course (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
