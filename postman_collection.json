            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Belajar JavaScript Modern (Updated)\",\n  \"price\": 199000,\n  \"discount_rate\": 30\n}"
            }
          }
        },
        {
          "name": "Delete Course (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/courses/4",
              "host": ["{{base_url}}"],
              "path": ["courses", "4"]
            }
